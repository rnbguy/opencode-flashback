{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "llm": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "openai-chat",
            "openai-responses",
            "anthropic",
            "gemini",
            "generic"
          ]
        },
        "model": {
          "type": "string"
        },
        "apiUrl": {
          "type": "string"
        },
        "apiKey": {
          "type": "string"
        }
      },
      "required": [
        "provider",
        "model",
        "apiUrl",
        "apiKey"
      ],
      "additionalProperties": false
    },
    "storage": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "additionalProperties": false
    },
    "memory": {
      "type": "object",
      "properties": {
        "maxResults": {
          "type": "number"
        },
        "autoCapture": {
          "type": "boolean"
        },
        "injection": {
          "type": "string",
          "enum": [
            "first",
            "every"
          ]
        },
        "excludeCurrentSession": {
          "type": "boolean"
        },
        "maxAgeDays": {
          "type": "number"
        }
      },
      "required": [
        "maxResults",
        "autoCapture",
        "injection",
        "excludeCurrentSession"
      ],
      "additionalProperties": false
    },
    "web": {
      "type": "object",
      "properties": {
        "port": {
          "type": "number"
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "port",
        "enabled"
      ],
      "additionalProperties": false
    },
    "search": {
      "type": "object",
      "properties": {
        "retrievalQuality": {
          "type": "string",
          "enum": [
            "fast",
            "balanced",
            "thorough",
            "custom"
          ]
        },
        "hybridWeights": {
          "type": "object",
          "properties": {
            "semantic": {
              "type": "number"
            },
            "keyword": {
              "type": "number"
            }
          },
          "required": [
            "semantic",
            "keyword"
          ],
          "additionalProperties": false
        },
        "rankingWeights": {
          "type": "object",
          "properties": {
            "recency": {
              "type": "number"
            },
            "importance": {
              "type": "number"
            },
            "semantic": {
              "type": "number"
            }
          },
          "required": [
            "recency",
            "importance",
            "semantic"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "retrievalQuality"
      ],
      "additionalProperties": false
    },
    "toasts": {
      "type": "object",
      "properties": {
        "autoCapture": {
          "type": "boolean"
        },
        "userProfile": {
          "type": "boolean"
        },
        "errors": {
          "type": "boolean"
        }
      },
      "required": [
        "autoCapture",
        "userProfile",
        "errors"
      ],
      "additionalProperties": false
    },
    "compaction": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "memoryLimit": {
          "type": "number"
        }
      },
      "required": [
        "enabled",
        "memoryLimit"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "llm",
    "storage",
    "memory",
    "web",
    "search",
    "toasts",
    "compaction"
  ],
  "additionalProperties": false
}
