{
  "name": "opencode-flashback",
  "version": "0.1.0",
  "type": "module",
  "description": "Persistent AI memory plugin for OpenCode -- free, local, open-source",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "schema.json",
    "SECURITY.md"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "memory",
    "ai",
    "embeddings",
    "flashback"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rnbguy/opencode-flashback.git"
  },
  "bugs": {
    "url": "https://github.com/rnbguy/opencode-flashback/issues"
  },
  "homepage": "https://github.com/rnbguy/opencode-flashback#readme",
  "license": "Apache-2.0",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "prepublishOnly": "bun run build && bun test",
    "prebuild": "mkdir -p dist/web",
    "build": "bun build src/index.ts --outdir dist --target bun --external onnxruntime-node && bun build src/web/app.ts --outdir dist/web --target browser --minify && tsc --emitDeclarationOnly --outDir dist && cp src/web/index.html src/web/styles.css src/web/favicon.ico dist/web/",
    "typecheck": "tsc --noEmit",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "generate:schema": "bun run scripts/generate-schema.ts",
    "prepare": "bunx husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.54",
    "@ai-sdk/google": "^3.0.37",
    "@ai-sdk/openai": "^3.0.39",
    "@huggingface/transformers": "^3.8.1",
    "@orama/orama": "^3.1.18",
    "ai": "^6.0.111",
    "iso-639-1": "^3.1.5",
    "ms": "^2.1.3",
    "tinyld": "^1.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/ms": "^2.1.0",
    "dompurify": "^3.3.1",
    "jsonrepair": "^3.13.2",
    "lucide": "^0.576.0",
    "marked": "^17.0.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.2.15"
  }
}
