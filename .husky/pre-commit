LC_ALL=C grep -rPn '[^\x00-\x7F]' src/ test/ scripts/ --include='*.ts' --include='*.html' --include='*.css' && echo "ERROR: non-ASCII characters found" && exit 1
gitleaks git --staged --no-banner --redact
bun run typecheck
COVERAGE_OUT=$(mktemp)
bun test --coverage >"$COVERAGE_OUT" 2>&1
TEST_EXIT=$?
cat "$COVERAGE_OUT"
if [ "$TEST_EXIT" -ne 0 ]; then rm -f "$COVERAGE_OUT"; exit 1; fi
AVG=$(awk -F'|' '/^ src\//{if($1 !~ /plugin\.ts/ && $1 !~ /search\.ts/) {gsub(/ /,"",$3); sum+=$3; n++}} END{if(n>0) printf "%.0f", sum/n; else print 0}' "$COVERAGE_OUT")
rm -f "$COVERAGE_OUT"
echo "Average line coverage: ${AVG}%"
if [ "$AVG" -lt 90 ]; then echo "ERROR: Coverage ${AVG}% is below 90% threshold"; exit 1; fi
bun run generate:schema
bunx biome format --write schema.json
bunx biome check .
git diff --quiet schema.json || git add schema.json
